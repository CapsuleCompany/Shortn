# Django
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite)
DATABASE_URL=
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_SECRET_KEY=change-me-to-a-real-jwt-secret
JWT_ACCESS_TOKEN_LIFETIME_DAYS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Short code
SHORT_CODE_LENGTH=6

# Rate limiting (requests per minute for anonymous users)
ANON_RATE_LIMIT=60/min
USER_RATE_LIMIT=120/min

# Base URL for short links (used in responses)
BASE_URL=http://localhost:8000
