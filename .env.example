# Django
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave blank/commented out to use SQLite locally.
# Set these via GitHub Secrets for production/CI (PostgreSQL).
# DB_NAME=shortn
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_SECRET_KEY=change-me-to-a-real-jwt-secret
JWT_ACCESS_TOKEN_LIFETIME_DAYS=1
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Redis — leave blank to use in-memory cache locally.
# Set via GitHub Secrets for production/CI.
# REDIS_URL=redis://localhost:6379/0

# Kafka — leave blank to disable event publishing.
# Set via docker-compose or production config.
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# KAFKA_CLIENT_ID=shortn

# Short code
SHORT_CODE_LENGTH=6

# Rate limiting (requests per minute for anonymous users)
ANON_RATE_LIMIT=60/min
USER_RATE_LIMIT=120/min

# Pagination
PAGE_SIZE=25

# Cache TTLs (seconds)
REDIRECT_CACHE_TTL=300
ANALYTICS_CACHE_TTL=30

# Base URL for short links (used in responses)
BASE_URL=http://localhost:8000
